{
  "name": "gcos-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node server/index.mjs",
    "start": "GCOS_SERVE_WEB=1 node server/index.mjs",
    "start:replit": "NODE_ENV=production GCOS_HOST=0.0.0.0 GCOS_DOMAIN=rmvi.org GCOS_DEPLOYMENT_TARGET=replit GCOS_SERVE_WEB=1 GCOS_ALLOWED_ORIGIN=https://rmvi.org GCOS_HEALTHCHECK_URL=https://rmvi.org GCOS_ENABLE_DEV_RESET=0 node server/index.mjs",
    "replit:run": "npm run build && npm run start:replit",
    "production:check": "node scripts/production-readiness.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test",
    "healthcheck": "node scripts/healthcheck.mjs",
    "domain:check": "node scripts/domain-check.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "pg": "^8.20.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
